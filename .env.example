# Copy this to .env and edit as needed
# Stockfish binary — leave blank to auto-detect from PATH
STOCKFISH_PATH=

# Path to YOLOv8 chess-piece weights (relative to project root or absolute)
YOLO_WEIGHTS=models/chess_pieces_yolov8n.pt

# Stockfish tuning
ENGINE_THREADS=1
ENGINE_HASH_MB=32

# Set to true to enable debug overlays in the UI
DEBUG=false
